# OPERIS — Variaveis de Ambiente (Producao)
# Copie: cp .env.example .env e preencha os valores

# IP publico do VPS (sem http://, sem porta)
VPS_IP=123.456.789.0

# Banco de Dados
# Gere uma senha: openssl rand -base64 24
POSTGRES_PASSWORD=troque_por_senha_forte_aqui

# JWT
# Gere uma chave: openssl rand -base64 32
JWT_SECRET=gere_com_openssl_rand_base64_32
JWT_EXPIRES_IN=8h

# Google Sheets API
GOOGLE_SERVICE_ACCOUNT_EMAIL=operis-service@seu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IDs das Planilhas por Turno
SHEET_ID_TURNO_1=
SHEET_ID_TURNO_2=
SHEET_ID_TURNO_3=

# Configuracoes Operacionais
SYNC_INTERVAL_MINUTES=1
ALERT_CICLO_DESVIO_PERCENT=10
ALERT_SETUP_MAX_MINUTOS=60
