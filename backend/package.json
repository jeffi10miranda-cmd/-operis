{
  "name": "operis-backend",
  "version": "1.0.0",
  "description": "OPERIS — Backend industrial Node.js",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "setup": "prisma migrate deploy && node dist/prisma/seed.js",
    "build": "npx prisma generate && npx tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
